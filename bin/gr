#!/usr/bin/env bash
set -euo pipefail
if [[ -n "${GR_HOME:-}" && -f "$GR_HOME/ecosystem.config.cjs" ]]; then
  ROOT="$GR_HOME"
else
  SCRIPT="${BASH_SOURCE[0]}"
  while [[ -L "$SCRIPT" ]]; do
    TARGET="$(readlink "$SCRIPT")"
    if [[ "$TARGET" != /* ]]; then
      SCRIPT="$(cd "$(dirname "$SCRIPT")" && pwd)/$TARGET"
    else
      SCRIPT="$TARGET"
    fi
  done
  ROOT="$(cd "$(dirname "$SCRIPT")/.." && pwd)"
fi
cd "$ROOT"
exec node --import tsx "$ROOT/bin/gr.ts" "$@"
